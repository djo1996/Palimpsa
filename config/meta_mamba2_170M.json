{
  "architectures": [
    "MetaMamba2ForCausalLM"
  ],
  "model_type": "meta_mamba2",
  "auto_map": {
    "AutoConfig": "fla.models.meta_mamba2.configuration_meta_mamba2.MetaMamba2Config",
    "AutoModelForCausalLM": "fla.models.meta_mamba2.modeling_meta_mamba2.MetaMamba2ForCausalLM"
  },
  "attn_mode": "chunk",
  "beta_step_rank": 48,
  "bos_token_id": 1,
  "chunk_size": 256,
  "conv_kernel": 4,
  "eos_token_id": 2,
  "expand": 2,
  "fuse_cross_entropy": true,
  "fuse_norm": true,
  "head_dim": 96,
  "hidden_act": "silu",
  "hidden_size": 768,
  "initializer_range": 0.02,
  "norm_eps": 1e-05,
  "n_groups": 1,
  "num_heads": 16,
  "num_hidden_layers": 32,
  "pad_token_id": 0,
  "rescale_prenorm_residual": true,
  "residual_in_fp32": true,
  "rms_norm": true,
  "state_size": 16,
  "tie_word_embeddings": true,
  "time_step_floor": 0.0001,
  "time_step_max": 0.1,
  "time_step_min": 0.001,
  "time_step_rank": 128,
  "use_bias": false,
  "use_cache": true,
  "use_conv_bias": true,
  "vocab_size": 32000,
  "metaplasticity": true,
  "finetuning": false
}
