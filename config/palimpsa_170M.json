{
  "architectures": [
    "PalimpsaForCausalLM"
  ],
  "model_type": "palimpsa",
  "auto_map": {
    "AutoConfig": "fla.models.palimpsa.configuration_palimpsa.PalimpsaConfig",
    "AutoModelForCausalLM": "fla.models.palimpsa.modeling_palimpsa.PalimpsaForCausalLM"
  },
  "attn_mode": "chunk",
  "beta_step_rank": 48,
  "bos_token_id": 1,
  "conv_size": 4,
  "eos_token_id": 2,
  "expand_v": 1,
  "fuse_cross_entropy": true,
  "head_dim": 48,
  "hidden_act": "swish",
  "hidden_ratio": 4,
  "hidden_size": 768,
  "initializer_range": 0.02,
  "intermediate_size": null,
  "norm_eps": 1e-06,
  "num_heads": 16,
  "num_hidden_layers": 19,
  "reduct_k": 1,
  "tie_word_embeddings": true,
  "use_cache": true,
  "use_gate": true,
  "use_short_conv": true,
  "vocab_size": 32000
}